// Schema for Laptop & Phone Shop Management - Personal Version
// Modules: Sales (POS), Repair/Service, Inventory, Customers, Users

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BRANCHES
// ============================================
model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  sales          Sale[]
  serviceTickets ServiceTicket[]
  stockMovements StockMovement[]
  productStocks  ProductBranchStock[]
  sessions       Session[]
}

// ============================================
// SETTINGS / APP CONFIG
// ============================================
model AppSetting {
  id              String   @id @default("default")
  shopName        String   @default("TechShop")
  siteTitle       String   @default("TechShop - Quản lý cửa hàng Laptop & Điện thoại")
  shopTagline     String   @default("Laptop & Điện thoại")
  shopAddress     String?
  shopPhone       String?
  shopEmail       String?
  logoUrl         String?
  faviconUrl      String?
  bankId          String?
  bankAccount     String?
  bankAccountName String?
  printSize       String   @default("A4") // A4 | 80mm
  updatedAt       DateTime @updatedAt

  // Atomic counters for human-readable codes
  lastSaleNumber     Int @default(0)
  lastTicketNumber   Int @default(0)
  lastCustomerNumber Int @default(0)
}

// ============================================
// USERS / AUTH
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  role         String   @default("staff") // admin, staff, technician
  active       Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Last login tracking
  lastLoginAt DateTime?
  lastIp      String?
  userAgent   String?

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  sessions        Session[]
  sales           Sale[]
  serviceTickets  ServiceTicket[] @relation("CreatedBy")
  serviceAssigned ServiceTicket[] @relation("AssignedTo")
  stockMovements  StockMovement[]
  notifications   Notification[]
}

// ============================================
// PRODUCT BRANCH STOCK
// ============================================
model ProductBranchStock {
  id    String @id @default(cuid())
  stock Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([branchId])
}

// ============================================
// NOTIFICATIONS (real-time alerts)
// ============================================
model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // ticket_assigned | ticket_status | low_stock | other
  title     String
  body      String?
  link      String? // URL to navigate when clicked
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// ============================================
// SESSIONS / DEVICE TRACKING
// ============================================
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userAgent String?
  ipAddress String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ============================================
// CUSTOMERS
// ============================================
model Customer {
  id        String   @id @default(cuid())
  code      String   @unique // KH001
  name      String
  phone     String   @unique
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales          Sale[]
  serviceTickets ServiceTicket[]
}

// ============================================
// CATEGORIES & PRODUCTS
// ============================================
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  type      String // laptop | phone | accessory | service
  skuPrefix String    @default("") // LT, DT, PK, DV
  icon      String    @default("") // lucide icon name
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  brand       String? // Apple, Dell, Samsung...
  description String?
  imageUrl    String?
  price       Float    @default(0) // selling price
  costPrice   Float    @default(0)
  stock       Int      @default(0) // running stock count
  warranty    Int      @default(0) // months
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  saleItems     SaleItem[]
  serviceItems  ServiceItem[]
  movements     StockMovement[]
  productStocks ProductBranchStock[]
}

// ============================================
// STOCK MOVEMENTS
// ============================================
model StockMovement {
  id        String   @id @default(cuid())
  type      String // in | out | adjust
  quantity  Int // delta
  before    Int // stock before
  after     Int // stock after
  unitCost  Float    @default(0)
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

// ============================================
// SALES (POS)
// ============================================
model Sale {
  id            String   @id @default(cuid())
  code          String   @unique // HD20240001
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  paymentMethod String   @default("cash")
  status        String   @default("paid")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items SaleItem[]
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  unitPrice Float
  discount  Float   @default(0)
  subtotal  Float
  imei      String?
  note      String?

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ============================================
// SERVICE / REPAIR
// ============================================
model ServiceTicket {
  id            String    @id @default(cuid())
  code          String    @unique // SC20240001
  deviceType    String
  deviceBrand   String?
  deviceModel   String?
  imei          String?
  accessories   String?
  appearance    String?
  problem       String
  diagnosis     String?
  solution      String?
  estimatedCost Float     @default(0)
  finalCost     Float     @default(0)
  deposit       Float     @default(0)
  paid          Float     @default(0)
  warranty      Int       @default(0)
  paymentMethod String?
  status        String    @default("received")
  receivedAt    DateTime  @default(now())
  promisedAt    DateTime?
  completedAt   DateTime?
  deliveredAt   DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items   ServiceItem[]
  history ServiceStatusHistory[]
}

model ServiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  subtotal    Float

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

model ServiceStatusHistory {
  id        String   @id @default(cuid())
  status    String
  note      String?
  createdAt DateTime @default(now())

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ============================================
// PRINT TEMPLATES
// ============================================
model PrintTemplate {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  content   String?
  updatedAt DateTime @updatedAt
}

// ============================================
// SYSTEM SETTINGS (Global Admin)
// ============================================
model SystemSetting {
  id              String   @id @default("global")
  platformName    String   @default("MyPOS")
  supportEmail    String   @default("support@mypos.vn")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}
