// Schema for Laptop & Phone Shop Management - Multi-tenant SaaS Version
// Modules: Sales (POS), Repair/Service, Inventory, Customers, Users, Tenant/Subscription

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANTS / SAAS SUBSCRIBERS
// ============================================
model Tenant {
  id     String  @id @default(cuid())
  slug   String  @unique // Subdomain prefix (e.g. apple-care)
  name   String
  active Boolean @default(true)

  // SaaS Subscription & 7-Day Trial
  trialExpiresAt        DateTime
  subscriptionPlan      String    @default("trial") // trial | basic | premium
  subscriptionExpiresAt DateTime?

  // Atomic per-tenant counters for human-readable codes (HDxxxxx / SCxxxxx
  // / KHxxxxx). Incremented via `update { increment: 1 }` so concurrent
  // sales/tickets/customers never share a code. On first use after this
  // migration, the counters are rolled forward past any pre-existing
  // codes — see src/lib/code-sequence.ts.
  lastSaleNumber     Int @default(0)
  lastTicketNumber   Int @default(0)
  lastCustomerNumber Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  settings       AppSetting[]
  customers      Customer[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  tickets        ServiceTicket[]
  templates      PrintTemplate[]
  stockMovements StockMovement[]
  sessions       Session[]
  branches       Branch[]
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  users          User[]
  sales          Sale[]
  serviceTickets ServiceTicket[]
  stockMovements StockMovement[]
  productStocks  ProductBranchStock[]
  sessions       Session[]

  @@index([tenantId])
}

// ============================================
// SETTINGS / APP CONFIG
// ============================================
model AppSetting {
  id              String   @id @default(cuid())
  shopName        String   @default("TechShop")
  siteTitle       String   @default("TechShop - Quản lý cửa hàng Laptop & Điện thoại")
  shopTagline     String   @default("Laptop & Điện thoại")
  shopAddress     String?
  shopPhone       String?
  shopEmail       String?
  logoUrl         String?
  faviconUrl      String?
  bankId          String?
  bankAccount     String?
  bankAccountName String?
  printSize       String   @default("A4") // A4 | 80mm
  updatedAt       DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============================================
// USERS / AUTH
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  role         String   @default("staff") // admin, staff, technician
  active       Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Last login tracking
  lastLoginAt DateTime?
  lastIp      String?
  userAgent   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  sessions        Session[]
  sales           Sale[]
  serviceTickets  ServiceTicket[] @relation("CreatedBy")
  serviceAssigned ServiceTicket[] @relation("AssignedTo")
  stockMovements  StockMovement[]
  notifications   Notification[]
}

// ============================================
// PRODUCT BRANCH STOCK
// ============================================
model ProductBranchStock {
  id    String @id @default(cuid())
  stock Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([branchId])
}

// ============================================
// NOTIFICATIONS (real-time alerts)
// ============================================
model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // ticket_assigned | ticket_status | low_stock | other
  title     String
  body      String?
  link      String? // URL to navigate when clicked
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// ============================================
// SESSIONS / DEVICE TRACKING
// ============================================
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userAgent String?
  ipAddress String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId])
}

// ============================================
// CUSTOMERS
// ============================================
model Customer {
  id        String   @id @default(cuid())
  code      String // KH001 (Unique per Tenant)
  name      String
  phone     String // (Unique per Tenant)
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sales          Sale[]
  serviceTickets ServiceTicket[]

  @@unique([tenantId, code])
  @@unique([tenantId, phone])
}

// ============================================
// CATEGORIES & PRODUCTS
// ============================================
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String
  type      String // laptop | phone | accessory | service
  skuPrefix String    @default("") // LT, DT, PK, DV
  icon      String    @default("") // lucide icon name: laptop, smartphone, wrench, headphones, etc.
  products  Product[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
}

model Product {
  id          String   @id @default(cuid())
  sku         String // Unique per Tenant
  name        String
  brand       String? // Apple, Dell, Samsung...
  description String?
  imageUrl    String?
  price       Float    @default(0) // selling price
  costPrice   Float    @default(0)
  stock       Int      @default(0) // running stock count
  warranty    Int      @default(0) // months
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  saleItems     SaleItem[]
  serviceItems  ServiceItem[]
  movements     StockMovement[]
  productStocks ProductBranchStock[]

  @@unique([tenantId, sku])
}

// ============================================
// STOCK MOVEMENTS (Nhập / Xuất / Kiểm kho)
// ============================================
model StockMovement {
  id        String   @id @default(cuid())
  type      String // in | out | adjust
  quantity  Int // delta — positive for in, negative for out, signed for adjust
  before    Int // stock before
  after     Int // stock after
  unitCost  Float    @default(0) // for "in" — giá nhập
  reason    String? // mua hàng / xuất sửa chữa / kiểm kê thiếu...
  reference String? // mã NCC / mã phiếu liên quan
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

// ============================================
// SALES (POS)
// ============================================
model Sale {
  id            String   @id @default(cuid())
  code          String // HD20240001 (Unique per Tenant)
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  paymentMethod String   @default("cash") // cash | card | transfer | wallet
  status        String   @default("paid") // paid | pending | cancelled
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items SaleItem[]

  @@unique([tenantId, code])
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  unitPrice Float
  discount  Float   @default(0)
  subtotal  Float
  imei      String? // IMEI / serial cho phone/laptop bán ra
  note      String?

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ============================================
// SERVICE / REPAIR
// ============================================
model ServiceTicket {
  id            String    @id @default(cuid())
  code          String // SC20240001 (Unique per Tenant)
  deviceType    String // laptop | phone | tablet | other
  deviceBrand   String? // Apple, Dell...
  deviceModel   String? // MacBook Pro 14, iPhone 15...
  imei          String? // IMEI / serial
  accessories   String? // pin, sạc, sim... đi kèm
  appearance    String? // trầy xước, móp...
  problem       String // Mô tả lỗi từ khách
  diagnosis     String? // Chẩn đoán của KTV
  solution      String? // Giải pháp / linh kiện thay
  estimatedCost Float     @default(0)
  finalCost     Float     @default(0)
  deposit       Float     @default(0) // cọc
  paid          Float     @default(0)
  warranty      Int       @default(0) // months on repair
  paymentMethod String? // cash | transfer
  status        String    @default("received") // received | diagnosing | waiting_parts | repairing | completed | delivered | cancelled
  receivedAt    DateTime  @default(now())
  promisedAt    DateTime? // hẹn trả
  completedAt   DateTime?
  deliveredAt   DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items   ServiceItem[]
  history ServiceStatusHistory[]

  @@unique([tenantId, code])
}

model ServiceItem {
  id          String @id @default(cuid())
  description String // Tên linh kiện / dịch vụ
  quantity    Int    @default(1)
  unitPrice   Float
  subtotal    Float

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

model ServiceStatusHistory {
  id        String   @id @default(cuid())
  status    String
  note      String?
  createdAt DateTime @default(now())

  ticketId String
  ticket   ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ============================================
// PRINT TEMPLATES
// ============================================
model PrintTemplate {
  id        String   @id @default(cuid())
  name      String // "Hóa đơn bán hàng", "Phiếu nhận máy", "Phiếu trả máy"
  slug      String // "sale-receipt", "service-intake", "service-return" (Unique per Tenant)
  content   String? // Full template layout
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
}
// ============================================
// SYSTEM SETTINGS (Global Admin)
// ============================================
model SystemSetting {
  id              String   @id @default("global")
  platformName    String   @default("MyPOS SaaS")
  supportEmail    String   @default("support@mypos.vn")
  maintenanceMode Boolean  @default(false)
  allowSignup     Boolean  @default(true)
  announcement    String?  // Global announcement text
  updatedAt       DateTime @updatedAt
}
