# Connection string for the Postgres database powering the app.
#
# Local development (matches docker-compose.yml in this repo):
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/saaspos?schema=public"

# Hosted Postgres (e.g. Supabase, Neon, Railway, AWS RDS) — copy from
# the provider's dashboard. The string must include a database name.
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public&sslmode=require"
